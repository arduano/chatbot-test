{
  "name": "chatbot-test",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "TanStack AI chatbot demos with Vite, React, and Express",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"tsx watch server/index.ts\" \"vite\"",
    "build": "tsc --noEmit && vite build",
    "start": "tsx server/index.ts"
  },
  "keywords": [
    "tanstack-ai",
    "vite",
    "react",
    "chatbot"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@tanstack/ai": "^0.8.1",
    "@tanstack/ai-client": "^0.7.2",
    "@tanstack/ai-openai": "^0.7.1",
    "@tanstack/ai-react": "^0.7.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  }
}
